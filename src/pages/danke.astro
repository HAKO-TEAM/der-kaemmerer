---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<Base title="Anmeldung bestätigt">
<Header />
<div style="background:linear-gradient(135deg,#1a2744 0%,#0f3460 60%,#1a3a5c 100%);padding:80px 0;text-align:center;">
  <div style="max-width:600px;margin:0 auto;padding:0 32px;">
    <div style="font-size:48px;margin-bottom:16px;">✓</div>
    <h1 style="font-size:28px;font-weight:800;color:#fff;margin-bottom:12px;">Anmeldung bestätigt</h1>
    <p style="font-size:15px;color:#93c5fd;line-height:1.7;margin-bottom:24px;">
      Sie erhalten das wöchentliche Briefing <strong style="color:#fff;">Der Kämmerer</strong> ab sofort jeden Montag direkt ins Postfach.
    </p>
    <a href="/" style="display:inline-block;background:#3b82f6;color:#fff;font-size:11px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;padding:10px 20px;border-radius:3px;">
      Zur Startseite
    </a>
  </div>
</div>
<Footer />
</Base>
