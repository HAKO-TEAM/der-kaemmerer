      <!-- ══ LOGO ══ -->
      <div class="f-section">
        <div class="f-section-head">
          <div class="f-section-icon">🖼️</div>
          <div>
            <h2>Logo Ihrer Organisation</h2>
            <p>PNG oder SVG, mindestens 200 × 200 px — optional, kann auch nachgereicht werden</p>
          </div>
        </div>

        <label class="f-upload-area" id="uploadArea">
          <input type="file" name="logo" accept="image/png,image/svg+xml,image/jpeg"
            onchange="handleFileUpload(this)">
          <div class="f-upload-icon" id="uploadIcon">📎</div>
          <div class="f-upload-text" id="uploadText">
            <strong>Datei auswählen</strong> oder hier hineinziehen
          </div>
          <div class="f-upload-hint">PNG, SVG oder JPG · max. 5 MB</div>
        </label>
      </div>

      <!-- ══ 4. KONTAKT & ADDONS ══ -->
      <div class="f-section" id="sectionKontakt">
        <div class="f-section-head">
          <div class="f-section-icon">👤</div>
          <div>
            <h2>Ihr Kontakt (intern)</h2>
            <p>Für Rückfragen zur Anzeige — wird nicht veröffentlicht</p>
          </div>
        </div>

        <div class="f-grid">
          <div class="f-field">
            <label class="f-label" for="kontaktname">Ihr Name <span class="req">*</span></label>
            <input class="f-input" id="kontaktname" name="kontaktname" type="text"
              placeholder="Vor- und Nachname" required>
          </div>

          <div class="f-field">
            <label class="f-label" for="kontaktemail">Ihre E-Mail <span class="req">*</span></label>
            <input class="f-input" id="kontaktemail" name="kontaktemail" type="email"
              placeholder="name@landkreis.de" required>
          </div>

          <div class="f-field">
            <label class="f-label" for="kontakttel">Telefon <span class="hint">optional</span></label>
            <input class="f-input" id="kontakttel" name="kontakttel" type="tel"
              placeholder="+49 30 123456">
          </div>

          <div class="f-field">
            <label class="f-label" for="rechnungsadresse">Rechnungsadresse <span class="hint">falls abweichend</span></label>
            <input class="f-input" id="rechnungsadresse" name="rechnungsadresse" type="text"
              placeholder="Behördenname, Straße, PLZ Ort">
          </div>
        </div>
      </div>

      <!-- ══ ADD-ONS ══ -->
      <div class="f-section">
        <div class="f-section-head">
          <div class="f-section-icon">⭐</div>
          <div>
            <h2>Zusatzleistungen</h2>
            <p>Optionale Erweiterungen — werden zur Rechnung addiert</p>
          </div>
        </div>

        <div class="f-addon-grid">
          <label class="f-addon">
            <input type="checkbox" name="addon_newsletter" value="Newsletter Solo-Mailing +390 €"
              onchange="updateSummary()">
            <div>
              <div class="f-addon-name">Newsletter Solo-Mailing</div>
              <div class="f-addon-price">+ 390 €</div>
              <div class="f-addon-desc">Dedizierte E-Mail an alle Abonnenten nur für Ihre Stelle</div>
            </div>
          </label>
          <label class="f-addon">
            <input type="checkbox" name="addon_linkedin" value="LinkedIn Sponsored Post +250 €"
              onchange="updateSummary()">
            <div>
              <div class="f-addon-name">LinkedIn Sponsored Post</div>
              <div class="f-addon-price">+ 250 €</div>
              <div class="f-addon-desc">Bezahlter Post auf dem derkaemmerer.de-Profil, 7 Tage</div>
            </div>
          </label>
          <label class="f-addon">
            <input type="checkbox" name="addon_portraet" value="Arbeitgeber-Porträt +450 €"
              onchange="updateSummary()">
            <div>
              <div class="f-addon-name">Arbeitgeber-Porträt</div>
              <div class="f-addon-price">+ 450 €</div>
              <div class="f-addon-desc">Redaktioneller Beitrag über Ihre Behörde (800 Wörter)</div>
            </div>
          </label>
          <label class="f-addon">
            <input type="checkbox" name="addon_beratung" value="Persönliche Beratung +0 €"
              onchange="updateSummary()">
            <div>
              <div class="f-addon-name">Persönliche Beratung</div>
              <div class="f-addon-price">kostenlos</div>
              <div class="f-addon-desc">Rückruf zur Anzeigengestaltung gewünscht</div>
            </div>
          </label>
        </div>
      </div>

      <!-- ══ ANMERKUNGEN ══ -->
      <div class="f-section">
        <div class="f-section-head">
          <div class="f-section-icon">💬</div>
          <div>
            <h2>Anmerkungen</h2>
            <p>Besondere Wünsche oder Hinweise an die Redaktion</p>
