<script>
// Fehlermeldung beim Laden immer zurücksetzen
document.getElementById('errorMsg')?.classList.remove('visible');

// ── KommunalFlat: Paket fix vorbelegt ───────────
// (kein Radio mehr nötig — hidden input)

// ── Preise ──────────────────────────────────────────────
const paketPreise: Record<string, number> = {
  'Basis – 290 €': 290,
  'Premium – 490 €': 490,
  'Exklusiv – 990 €': 990,
};
const addonPreise: Record<string, number> = {
  addon_newsletter: 390,
  addon_linkedin:   250,
  addon_portraet:   450,
};
let selectedPaket = 'KommunalFlat – 249 €/Monat';

// ── Zusammenfassung aktualisieren ───────────────────────
function updateSummary() {
  const sumPaket    = document.getElementById('sum-paket');
  const sumTotal    = document.getElementById('sum-total');
  const sumAddons   = document.getElementById('sum-addons');
  const sumAddonRow = document.getElementById('sum-addon-row') as HTMLElement;

  const base = paketPreise[selectedPaket] || 0;
  let addonTotal = 0;
  const addonLabels: string[] = [];

  Object.entries(addonPreise).forEach(([name, price]) => {
    const el = document.querySelector<HTMLInputElement>(`input[name="${name}"]`);
    if (el?.checked) { addonTotal += price; addonLabels.push(`+${price} €`); }
  });

  if (sumPaket)    sumPaket.textContent    = selectedPaket || '— noch nicht gewählt';
  if (sumAddonRow) sumAddonRow.style.display = addonLabels.length ? 'flex' : 'none';
  if (sumAddons)   sumAddons.textContent   = addonLabels.join(', ') || '—';

  const total = base + addonTotal;
  if (sumTotal) sumTotal.textContent = total > 0 ? `${total.toLocaleString('de-DE')} €` : '—';
}

// ── Paket auswählen ─────────────────────────────────────
function selectPaket(value: string, card: HTMLElement) {
  document.querySelectorAll('.f-paket-card').forEach(c => c.classList.remove('selected'));
  card.classList.add('selected');
  selectedPaket = value;
  // Radio-Input explizit setzen (nötig bei programmatischer Auswahl)
  const radio = card.querySelector<HTMLInputElement>('input[type="radio"]');
  if (radio) radio.checked = true;
  updateSummary();
}

// ── Event-Listener: Paketkarten ─────────────────────────
document.querySelectorAll<HTMLElement>('.f-paket-card').forEach(card => {
  card.addEventListener('click', () => {
    const value = card.dataset.paket || '';
    if (value) selectPaket(value, card);
  });
});

// ── Event-Listener: Add-on Checkboxen ───────────────────
document.querySelectorAll<HTMLInputElement>('.addon-check').forEach(cb => {
  cb.addEventListener('change', updateSummary);
});

// ── Zeichenzähler ────────────────────────────────────────
document.getElementById('kurzbeschreibung')?.addEventListener('input', (e) => {
  const counter = document.getElementById('count-kurz');
  if (counter) counter.textContent = String((e.target as HTMLTextAreaElement).value.length);
});

// ── Reply-To synchronisieren ────────────────────────────
document.getElementById('kontaktemail')?.addEventListener('input', (e) => {
  const field = document.getElementById('replyToField') as HTMLInputElement;
  if (field) field.value = (e.target as HTMLInputElement).value;
});

// ── URL-Parameter: Paket vorauswählen ───────────────────
const paketParam = new URLSearchParams(window.location.search).get('paket');
if (paketParam) {
  const map: Record<string, [string, string]> = {
    basis:    ['card-basis',    'Basis – 290 €'],
    premium:  ['card-premium',  'Premium – 490 €'],
    exklusiv: ['card-exklusiv', 'Exklusiv – 990 €'],
  };
  const entry = map[paketParam.toLowerCase()];
  if (entry) {
    const card = document.getElementById(entry[0]);
    if (card) selectPaket(entry[1], card);
  }
}

// ── Formular absenden via fetch → eigene Danke-Seite ───
document.getElementById('anzeigenForm')?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const form = e.target as HTMLFormElement;

  // Pflichtfeld: Paket gewählt?
  if (!selectedPaket) {
    const sec = document.getElementById('sectionPaket');
    sec?.scrollIntoView({ behavior: 'smooth' });
    if (sec) { sec.style.outline = '2px solid #dc2626'; setTimeout(() => { sec.style.outline = ''; }, 3000); }
    return;
  }

  const btn = document.getElementById('submitBtn') as HTMLButtonElement;
  const span = btn.querySelector('span') as HTMLSpanElement;
  btn.disabled = true;
  span.textContent = 'Wird gesendet …';

  try {
    const fd = new FormData(form);
    const data: Record<string, string> = {};
    fd.forEach((v, k) => { if (typeof v === 'string') data[k] = v; });

    const res = await fetch(form.action, {
      method: 'POST',
      body: JSON.stringify(data),
      headers: { 'Accept': 'application/json', 'Content-Type': 'application/json' }
    });

    if (res.ok) {
      // Weiterleitung auf unsere eigene Danke-Seite
      window.location.href = '/buchung-danke';
    } else {
      const data = await res.json().catch(() => ({}));
      throw new Error((data as any).error || 'Server-Fehler');
    }
  } catch (err) {
    const errEl = document.getElementById('errorMsg');
    if (errEl) errEl.classList.add('visible');
    btn.disabled = false;
    span.textContent = 'Anzeige verbindlich buchen';
  }
});

// ── Fortschrittsleiste ──────────────────────────────────
const sections = ['sectionPaket','sectionStelle','sectionText','sectionKontakt'];
const steps    = ['step1','step2','step3','step4'];
window.addEventListener('scroll', () => {
  let current = 0;
  sections.forEach((id, i) => {
    const el = document.getElementById(id);
    if (el && window.scrollY >= el.offsetTop - 200) current = i;
  });
  steps.forEach((id, i) => {
    const el = document.getElementById(id);
    if (!el) return;
    el.classList.remove('active', 'done');
    if (i < current)       el.classList.add('done');
    else if (i === current) el.classList.add('active');
  });
}, { passive: true });
</script>
