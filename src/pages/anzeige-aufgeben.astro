        </div>
        <div class="f-field">
          <textarea class="f-textarea" name="anmerkungen" rows="3"
            placeholder="z.B. gewünschtes Veröffentlichungsdatum, besondere Formatierungswünsche …"></textarea>
        </div>
      </div>

      <!-- ══ ZUSAMMENFASSUNG & ABSENDEN ══ -->
      <div class="f-summary" id="summary">
        <div class="f-summary-title">📋 Ihre Buchungsübersicht</div>
        <div class="f-summary-row"><span>Paket</span><span id="sum-paket">— noch nicht gewählt</span></div>
        <div class="f-summary-row" id="sum-addon-row" style="display:none"><span>Zusatzleistungen</span><span id="sum-addons">—</span></div>
        <div class="f-summary-row total"><span>Gesamtbetrag (netto)</span><span id="sum-total">—</span></div>
        <div style="font-size:11px;color:#065f46;margin-top:8px">zzgl. gesetzlicher Mehrwertsteuer · Rechnung nach Schaltung · Zahlung innerhalb 14 Tagen</div>
      </div>

      <!-- Hidden Spam-Schutz -->
      <input type="text" name="_gotcha" style="display:none">
      <input type="hidden" name="_subject" value="Neue Stellenanzeige – derkaemmerer.de">
      <input type="hidden" name="_replyto" id="replyToField" value="">

      <div class="f-submit-wrap">
        <button type="submit" class="f-submit" id="submitBtn">
          <span>Anzeige verbindlich buchen</span>
          <span>→</span>
        </button>
        <p class="f-submit-note">
          Mit dem Absenden bestätigen Sie die Buchung. Sie erhalten innerhalb von 4 Stunden eine Bestätigung. Die Rechnung folgt nach Schaltung.
        </p>
      </div>

