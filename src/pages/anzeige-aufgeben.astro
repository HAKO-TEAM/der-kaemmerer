<Footer />
</Base>

<script>
// URL-Parameter: Paket vorauswählen
const params = new URLSearchParams(window.location.search);
const paketParam = params.get('paket');
if (paketParam) {
  const map: Record<string, string> = { basis: 'card-basis', premium: 'card-premium', exklusiv: 'card-exklusiv' };
  const cardId = map[paketParam.toLowerCase()];
  if (cardId) {
    const card = document.getElementById(cardId) as HTMLElement;
    const values: Record<string, string> = { basis: 'Basis – 290 €', premium: 'Premium – 490 €', exklusiv: 'Exklusiv – 990 €' };
    if (card) { selectPaket(values[paketParam.toLowerCase()], card); card.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
  }
}

// Paket-Auswahl
const paketPreise: Record<string, number> = {
  'Basis – 290 €': 290,
  'Premium – 490 €': 490,
  'Exklusiv – 990 €': 990,
};
let selectedPaket = '';

function selectPaket(value: string, card: HTMLElement) {
  document.querySelectorAll('.f-paket-card').forEach(c => c.classList.remove('selected'));
  card.classList.add('selected');
  selectedPaket = value;
  updateSummary();
}

// Zeichenzähler
function updateCount(el: HTMLTextAreaElement, countId: string) {
  const counter = document.getElementById(countId);
  if (counter) counter.textContent = String(el.value.length);
}

// Zusammenfassung
function updateSummary() {
  const sumPaket = document.getElementById('sum-paket');
  const sumTotal = document.getElementById('sum-total');
  const sumAddons = document.getElementById('sum-addons');
  const sumAddonRow = document.getElementById('sum-addon-row');

  let base = paketPreise[selectedPaket] || 0;
  let addonTotal = 0;
  const addonLabels: string[] = [];

  const addonMap: Record<string, number> = {
    'addon_newsletter': 390,
    'addon_linkedin':   250,
    'addon_portraet':   450,
  };

  Object.entries(addonMap).forEach(([name, price]) => {
    const el = document.querySelector(`input[name="${name}"]`) as HTMLInputElement;
    if (el?.checked) { addonTotal += price; addonLabels.push(`+${price} €`); }
  });

  if (sumPaket) sumPaket.textContent = selectedPaket || '— noch nicht gewählt';
  if (sumAddonRow) sumAddonRow.style.display = addonLabels.length ? 'flex' : 'none';
  if (sumAddons) sumAddons.textContent = addonLabels.join(', ') || '—';

  const total = base + addonTotal;
  if (sumTotal) sumTotal.textContent = total > 0 ? `${total.toLocaleString('de-DE')} €` : '—';
}

// Logo-Upload Feedback
function handleFileUpload(input: HTMLInputElement) {
  const icon = document.getElementById('uploadIcon');
  const text = document.getElementById('uploadText');
  if (input.files && input.files[0] && icon && text) {
    icon.textContent = '✅';
    text.innerHTML = `<strong>${input.files[0].name}</strong>`;
  }
}

// Reply-To synchronisieren
document.getElementById('kontaktemail')?.addEventListener('input', (e) => {
  const field = document.getElementById('replyToField') as HTMLInputElement;
  if (field) field.value = (e.target as HTMLInputElement).value;
});

// Formular-Submit
document.getElementById('anzeigenForm')?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const form = e.target as HTMLFormElement;
  const btn = document.getElementById('submitBtn') as HTMLButtonElement;
  btn.disabled = true;
  btn.querySelector('span')!.textContent = 'Wird gesendet …';

  try {
    const data = new FormData(form);
    const res = await fetch(form.action, {
      method: 'POST', body: data,
      headers: { 'Accept': 'application/json' }
    });
    if (res.ok) {
      form.style.display = 'none';
      document.getElementById('successMsg')!.classList.add('visible');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    } else {
      throw new Error('Server error');
    }
  } catch {
    const errEl = document.getElementById('errorMsg')!;
    errEl.classList.add('visible');
    btn.disabled = false;
    btn.querySelector('span')!.textContent = 'Anzeige verbindlich buchen';
  }
});

// Scroll-Fortschritt
const sections = ['sectionPaket','sectionStelle','sectionText','sectionKontakt'];
const steps    = ['step1','step2','step3','step4'];
window.addEventListener('scroll', () => {
  let current = 0;
  sections.forEach((id, i) => {
    const el = document.getElementById(id);
    if (el && window.scrollY >= el.offsetTop - 200) current = i;
  });
  steps.forEach((id, i) => {
    const el = document.getElementById(id);
    if (!el) return;
    el.classList.remove('active','done');
    if (i < current)      el.classList.add('done');
    else if (i === current) el.classList.add('active');
  });
});
</script>
