---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<Base
  title="Gastbeitrag einreichen"
  description="Schreiben Sie für Der Kämmerer. Wir freuen uns über Praxisbeiträge von Kämmererinnen, Sozialdezernenten und kommunalen Fachleuten."
>
<Header />

<style>
  .hero { background:linear-gradient(135deg,#1a2744 0%,#0f3460 60%,#1a3a5c 100%); padding:52px 0; }
  .hero-inner { max-width:780px; margin:0 auto; padding:0 32px; }
  .hero h1 { font-size:32px; font-weight:800; color:#fff; margin-bottom:10px; letter-spacing:-.02em; }
  .hero p { font-size:14px; color:#93c5fd; line-height:1.7; }

  .main { max-width:780px; margin:0 auto; padding:44px 32px 64px; }

  .section { margin-bottom:40px; }
  .section h2 { font-size:18px; font-weight:800; color:#1a2744; border-bottom:2.5px solid #3b82f6; padding-bottom:8px; margin-bottom:16px; }
  .section p { font-size:14px; color:#374151; line-height:1.78; margin-bottom:12px; }
  .section p:last-child { margin-bottom:0; }
  .section strong { color:#1a2744; font-weight:700; }

  /* Kriterien-Grid */
  .krit-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:14px; margin-top:4px; }
  .krit { background:#f8fafc; border:1.5px solid #e2e8f0; border-left:3px solid #3b82f6; border-radius:6px; padding:14px 16px; }
  .krit-title { font-size:12px; font-weight:800; color:#1a2744; margin-bottom:4px; }
  .krit-text { font-size:12px; color:#6b7280; line-height:1.55; }

  /* Formular */
  .form-box { background:#fff; border:1.5px solid #e2e8f0; border-radius:8px; padding:32px; }
  .form-row { margin-bottom:20px; }
  .form-row label { display:block; font-size:11px; font-weight:700; color:#1a2744; letter-spacing:.05em; text-transform:uppercase; margin-bottom:6px; }
  .form-row input,
  .form-row select,
  .form-row textarea {
    width:100%; padding:10px 12px; font-size:13px; font-family:inherit;
    border:1.5px solid #e2e8f0; border-radius:4px; background:#f8fafc; color:#1a2744;
    outline:none; transition:border-color .15s;
  }
  .form-row input:focus,
  .form-row select:focus,
  .form-row textarea:focus { border-color:#3b82f6; background:#fff; }
  .form-row textarea { resize:vertical; min-height:110px; }
  .form-2col { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
  .form-hint { font-size:10px; color:#9ca3af; margin-top:4px; }
  .form-submit {
    background:#3b82f6; color:#fff; font-size:12px; font-weight:700;
    letter-spacing:.07em; text-transform:uppercase; padding:12px 28px;
    border:none; border-radius:3px; cursor:pointer; transition:background .15s;
    width:100%;
  }
  .form-submit:hover { background:#0f3460; }
  .form-submit:disabled { background:#93c5fd; cursor:not-allowed; }

  /* Feedback */
  .msg-ok { display:none; background:#f0fdf4; border:1.5px solid #86efac; border-radius:6px; padding:20px; text-align:center; }
  .msg-ok h3 { font-size:16px; font-weight:800; color:#166534; margin-bottom:6px; }
  .msg-ok p { font-size:13px; color:#15803d; }
  .msg-err { display:none; background:#fef2f2; border:1.5px solid #fca5a5; border-radius:6px; padding:14px 16px; margin-bottom:16px; font-size:13px; color:#991b1b; }

  @media(max-width:768px) {
    .hero-inner,.main { padding-left:16px; padding-right:16px; }
    .hero h1 { font-size:24px; }
    .krit-grid { grid-template-columns:1fr; }
    .form-2col { grid-template-columns:1fr; }
    .form-box { padding:20px 16px; }
  }
</style>

<div class="hero">
  <div class="hero-inner">
    <div style="font-size:9px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#0e7490;margin-bottom:10px;">Mitmachen</div>
    <h1>Gastbeitrag einreichen</h1>
    <p>Praktische Erfahrungen aus kommunaler Steuerung, Haushaltskonsolidierung und Sozialkosten — von Fachleuten für Fachleute.</p>
  </div>
</div>

<main class="main">

  <div class="section">
    <h2>Was wir suchen</h2>
    <p>Der Kämmerer publiziert Gastbeiträge von <strong>Praktikern</strong>: Kämmererinnen, Sozialdezernenten, Jugendamtsleitungen, kommunale Berater. Kein akademischer Aufsatz — sondern <strong>konkrete Erfahrungen</strong>, die anderen kommunalen Entscheidern weiterhelfen.</p>
    <div class="krit-grid">
      <div class="krit">
        <div class="krit-title">Operativer Fokus</div>
        <div class="krit-text">Was haben Sie eingeführt, entschieden oder verändert? Was hat funktioniert — und was nicht?</div>
      </div>
      <div class="krit">
        <div class="krit-title">Praxisrelevanz</div>
        <div class="krit-text">Der Beitrag beantwortet: Was kann ein Kämmerer damit morgen früh anfangen?</div>
      </div>
      <div class="krit">
        <div class="krit-title">Quellenbasiert</div>
        <div class="krit-text">Zahlen und Aussagen belegt. Keine unbelegten Behauptungen, keine Eigenwerbung.</div>
      </div>
      <div class="krit">
        <div class="krit-title">Umfang</div>
        <div class="krit-text">800–1.800 Wörter. Kürzere Beiträge als Kommentar oder Praxistipp ebenfalls willkommen.</div>
      </div>
    </div>
  </div>

  <div class="section">
    <h2>Beitrag einreichen</h2>
    <div class="form-box">
      <div class="msg-err" id="errMsg"></div>
      <form id="gastForm">
        <div class="form-2col">
          <div class="form-row">
            <label>Name *</label>
            <input type="text" name="name" placeholder="Vorname Nachname" required />
          </div>
          <div class="form-row">
            <label>Organisation / Kommune *</label>
            <input type="text" name="organisation" placeholder="Stadt Musterstadt / GmbH" required />
          </div>
        </div>
        <div class="form-row">
          <label>E-Mail *</label>
          <input type="email" name="email" placeholder="name@kommune.de" required />
        </div>
        <div class="form-row">
          <label>Funktion / Rolle</label>
          <input type="text" name="rolle" placeholder="z.B. Kämmerer, Sozialdezernentin, Berater" />
        </div>
        <div class="form-row">
          <label>Ressort *</label>
          <select name="ressort" required>
            <option value="">— bitte wählen —</option>
            <option>Haushalt & Finanzen</option>
            <option>Einnahmen erschließen</option>
            <option>Ausgaben steuern</option>
            <option>Sozialkosten & HzE</option>
            <option>Best Practice</option>
            <option>Recht & Vergabe</option>
            <option>Analyse & Meinung</option>
          </select>
        </div>
        <div class="form-row">
          <label>Arbeitstitel / Thema *</label>
          <input type="text" name="titel" placeholder="Wie unsere Stadt die HzE-Kosten um 18 % senkte" required />
        </div>
        <div class="form-row">
          <label>Kurzbeschreibung *</label>
          <textarea name="beschreibung" placeholder="Worum geht es? Was ist die zentrale These oder der Praxisfall? (3–5 Sätze)" required></textarea>
          <div class="form-hint">3–5 Sätze genügen. Wir melden uns innerhalb von 5 Werktagen.</div>
        </div>
        <div class="form-row">
          <label>Link zum Entwurf <span style="font-weight:400;text-transform:none;letter-spacing:0;">(optional)</span></label>
          <input type="url" name="link" placeholder="https://docs.google.com/… oder WeTransfer-Link" />
          <div class="form-hint">Google Docs, Dropbox, WeTransfer — oder Sie schicken uns den Text nach unserer Rückmeldung.</div>
        </div>
        <button type="submit" class="form-submit" id="submitBtn">Beitrag einreichen</button>
      </form>
      <div class="msg-ok" id="okMsg">
        <h3>Vielen Dank!</h3>
        <p>Ihre Einreichung ist bei uns eingegangen. Wir melden uns innerhalb von 5 Werktagen unter der angegebenen E-Mail-Adresse.</p>
      </div>
    </div>
  </div>

</main>
<Footer />

<script>
  const form = document.getElementById('gastForm') as HTMLFormElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
  const okMsg = document.getElementById('okMsg') as HTMLElement;
  const errMsg = document.getElementById('errMsg') as HTMLElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Wird gesendet …';
    errMsg.style.display = 'none';

    const data = Object.fromEntries(new FormData(form));

    try {
      const res = await fetch('/api/gastbeitrag', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (res.ok) {
        form.style.display = 'none';
        okMsg.style.display = 'block';
      } else {
        throw new Error('Fehler beim Senden');
      }
    } catch {
      errMsg.textContent = 'Leider ist ein Fehler aufgetreten. Bitte senden Sie Ihre Einreichung direkt an redaktion@derkaemmerer.de.';
      errMsg.style.display = 'block';
      submitBtn.disabled = false;
      submitBtn.textContent = 'Beitrag einreichen';
    }
  });
</script>
</Base>
