---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<Base
  title="ASCEND — KI-gestützte HzE-Steuerung"
  description="ASCEND gibt Kämmereien und Jugendämtern die Steuerungshoheit über Hilfen zur Erziehung zurück. Datenbasiert, operativ, ohne Systemwechsel."
  ogType="website"
>
<Header />

<style>
  .hero { background:linear-gradient(135deg,#1a2744 0%,#0f3460 60%,#1a3a5c 100%); padding:64px 0; }
  .hero-inner { max-width:1100px; margin:0 auto; padding:0 32px; display:grid; grid-template-columns:1fr 400px; gap:60px; align-items:center; }
  .hero-badge { font-size:9px; font-weight:700; letter-spacing:.14em; text-transform:uppercase; color:#6ee7b7; margin-bottom:14px; }
  .hero h1 { font-size:36px; font-weight:800; color:#fff; line-height:1.15; letter-spacing:-.02em; margin-bottom:16px; }
  .hero h1 span { color:#3b82f6; }
  .hero-sub { font-size:15px; color:#93c5fd; line-height:1.7; margin-bottom:28px; }
  .hero-stats { display:flex; gap:32px; }
  .hero-stat-val { font-size:28px; font-weight:800; color:#fff; line-height:1; }
  .hero-stat-label { font-size:11px; color:#64748b; margin-top:3px; }

  /* Formular-Box */
  .form-box { background:#fff; border-radius:8px; padding:32px; box-shadow:0 20px 60px rgba(0,0,0,.3); }
  .form-box h3 { font-size:17px; font-weight:800; color:#1a2744; margin-bottom:4px; }
  .form-box p { font-size:12px; color:#6b7280; margin-bottom:20px; line-height:1.5; }
  .form-row { margin-bottom:14px; }
  .form-row label { display:block; font-size:10px; font-weight:700; color:#1a2744; letter-spacing:.06em; text-transform:uppercase; margin-bottom:5px; }
  .form-row input, .form-row select { width:100%; padding:9px 12px; font-size:13px; font-family:inherit; border:1.5px solid #e2e8f0; border-radius:4px; background:#f8fafc; color:#1a2744; outline:none; transition:border-color .15s; }
  .form-row input:focus, .form-row select:focus { border-color:#3b82f6; background:#fff; }
  .form-submit { width:100%; background:#3b82f6; color:#fff; font-size:12px; font-weight:700; letter-spacing:.07em; text-transform:uppercase; padding:12px; border:none; border-radius:4px; cursor:pointer; transition:background .15s; margin-top:4px; }
  .form-submit:hover { background:#1a2744; }
  .form-ok { display:none; text-align:center; padding:20px 0; }
  .form-ok h4 { font-size:16px; font-weight:800; color:#065f46; margin-bottom:6px; }
  .form-ok p { font-size:13px; color:#374151; }

  /* Problem-Section */
  .section { max-width:1100px; margin:0 auto; padding:64px 32px; }
  .section-label { font-size:9px; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:#3b82f6; margin-bottom:12px; }
  .section h2 { font-size:28px; font-weight:800; color:#1a2744; letter-spacing:-.02em; margin-bottom:16px; }
  .section-sub { font-size:15px; color:#374151; line-height:1.75; max-width:680px; margin-bottom:48px; }

  .problem-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; margin-bottom:64px; }
  .problem-card { background:#fff; border:1.5px solid #e2e8f0; border-top:3px solid #c2410c; border-radius:6px; padding:20px; }
  .problem-card h4 { font-size:13px; font-weight:800; color:#1a2744; margin-bottom:8px; }
  .problem-card p { font-size:12px; color:#374151; line-height:1.6; }

  .solution-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; margin-bottom:64px; }
  .solution-card { background:#fff; border:1.5px solid #e2e8f0; border-top:3px solid #3b82f6; border-radius:6px; padding:20px; }
  .solution-card h4 { font-size:13px; font-weight:800; color:#1a2744; margin-bottom:8px; }
  .solution-card p { font-size:12px; color:#374151; line-height:1.6; }

  /* Zitat */
  .quote-section { background:#1a2744; padding:48px 0; margin-bottom:0; }
  .quote-inner { max-width:780px; margin:0 auto; padding:0 32px; text-align:center; }
  .quote-text { font-size:20px; font-weight:700; color:#fff; line-height:1.5; margin-bottom:16px; font-style:italic; }
  .quote-source { font-size:11px; color:#64748b; letter-spacing:.06em; text-transform:uppercase; }

  /* ROI */
  .roi-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:20px; margin-bottom:48px; }
  .roi-card { text-align:center; background:#fff; border:1px solid #e2e8f0; border-radius:6px; padding:24px 16px; }
  .roi-val { font-size:32px; font-weight:800; color:#3b82f6; line-height:1; margin-bottom:6px; }
  .roi-label { font-size:11px; color:#374151; line-height:1.4; }

  /* CTA-Section */
  .cta-section { background:#eff6ff; border-top:1px solid #bfdbfe; padding:64px 0; }
  .cta-inner { max-width:700px; margin:0 auto; padding:0 32px; text-align:center; }
  .cta-inner h2 { font-size:28px; font-weight:800; color:#1a2744; margin-bottom:12px; letter-spacing:-.02em; }
  .cta-inner p { font-size:14px; color:#374151; line-height:1.7; margin-bottom:28px; }
  .cta-btn { display:inline-block; background:#3b82f6; color:#fff; font-size:12px; font-weight:700; letter-spacing:.07em; text-transform:uppercase; padding:14px 32px; border-radius:4px; transition:background .15s; }
  .cta-btn:hover { background:#1a2744; }

  @media(max-width:1024px) {
    .hero-inner { grid-template-columns:1fr; gap:40px; }
    .hero-stats { flex-wrap:wrap; gap:20px; }
    .problem-grid, .solution-grid { grid-template-columns:1fr 1fr; }
    .roi-grid { grid-template-columns:repeat(2,1fr); }
  }
  @media(max-width:768px) {
    .hero { padding:40px 0; }
    .hero-inner, .section { padding-left:16px; padding-right:16px; }
    .hero h1 { font-size:26px; }
    .problem-grid, .solution-grid { grid-template-columns:1fr; }
    .roi-grid { grid-template-columns:1fr 1fr; }
    .quote-inner, .cta-inner { padding-left:16px; padding-right:16px; }
  }
</style>

<!-- Hero -->
<div class="hero">
  <div class="hero-inner">
    <div>
      <div class="hero-badge">HAKO · KI-Plattform für kommunale Steuerung</div>
      <h1>Die teuersten Fälle werden nicht durch die Kommune gesteuert — <span>der Träger entscheidet.</span></h1>
      <p class="hero-sub">ASCEND gibt Kämmereien und Jugendämtern die Steuerungshoheit über Hilfen zur Erziehung zurück. Datenbasiert, operativ einsetzbar — ohne Systemwechsel.</p>
      <div class="hero-stats">
        <div>
          <div class="hero-stat-val">10–14×</div>
          <div class="hero-stat-label">Durchschnittlicher ROI<br>in Pilotkommunen</div>
        </div>
        <div>
          <div class="hero-stat-val">+44 %</div>
          <div class="hero-stat-label">HzE-Kostensteigerung<br>seit 2013 bundesweit</div>
        </div>
        <div>
          <div class="hero-stat-val">ab 48k €</div>
          <div class="hero-stat-label">Jahreslizenz je nach<br>Fallzahl</div>
        </div>
      </div>
    </div>

    <!-- Demo-Formular -->
    <div class="form-box">
      <h3>Demo-Termin anfragen</h3>
      <p>30 Minuten. Keine Präsentation — eine direkte Analyse Ihrer Steuerungssituation.</p>
      <form id="demoForm">
        <div class="form-row">
          <label>Name *</label>
          <input type="text" name="name" placeholder="Vorname Nachname" required />
        </div>
        <div class="form-row">
          <label>Funktion *</label>
          <select name="funktion" required>
            <option value="">— bitte wählen —</option>
            <option>Kämmerer / Kämmerin</option>
            <option>Sozialdezernent / -dezernentin</option>
            <option>Jugendamtsleitung</option>
            <option>Oberbürgermeister / -bürgermeisterin</option>
            <option>Beigeordnete/r</option>
            <option>Sonstige Verwaltungsführung</option>
          </select>
        </div>
        <div class="form-row">
          <label>Kommune *</label>
          <input type="text" name="kommune" placeholder="Stadt / Landkreis" required />
        </div>
        <div class="form-row">
          <label>Dienstliche E-Mail *</label>
          <input type="email" name="email" placeholder="name@stadt.de" required />
        </div>
        <button type="submit" class="form-submit" id="demoSubmit">Demo-Termin anfragen →</button>
      </form>
      <div class="form-ok" id="demoOk">
        <h4>✓ Anfrage erhalten</h4>
        <p>Wir melden uns innerhalb von 24 Stunden unter der angegebenen E-Mail-Adresse.</p>
      </div>
    </div>
  </div>
</div>

<!-- Problem -->
<div class="section">
  <div class="section-label">Das Problem</div>
  <h2>Warum HzE-Kosten außer Kontrolle geraten</h2>
  <p class="section-sub">Hilfen zur Erziehung sind der am schnellsten wachsende Ausgabenposten in deutschen Kommunalhaushalten. Die Ursache liegt nicht im fehlenden Willen zur Steuerung — sondern in struktureller Informationsasymmetrie.</p>

  <div class="problem-grid">
    <div class="problem-card">
      <h4>Der Träger steuert, die Kommune zahlt</h4>
      <p>Träger entscheiden über Maßnahmenart, Intensität und Dauer — die Kommune erhält die Rechnung. Steuerungshoheit und Zahlungspflicht fallen auseinander.</p>
    </div>
    <div class="problem-card">
      <h4>Hochkostenfälle sind unsichtbar</h4>
      <p>Die teuersten Fälle — oft über 5.000 € pro Monat — werden nicht systematisch identifiziert. Es gibt kein Frühwarnsystem, das Eskalationen vor der Rechnung sichtbar macht.</p>
    </div>
    <div class="problem-card">
      <h4>Kein Outcome-Monitoring</h4>
      <p>Was passiert nach der Maßnahme? Rückkehr in die Familie, Verselbständigung, Folgehilfe? Diese Daten liegen nicht vor — Wirksamkeit ist nicht messbar.</p>
    </div>
  </div>

  <div class="section-label">Die Lösung</div>
  <h2>ASCEND — operative Steuerungshoheit zurückgewinnen</h2>
  <p class="section-sub">ASCEND analysiert auf META-Ebene: keine Systemintegration, kein Datenschutzproblem. Die Plattform macht sichtbar, was bisher unsichtbar war — und liefert konkrete Steuerungsimpulse.</p>

  <div class="solution-grid">
    <div class="solution-card">
      <h4>Hochrisiko-Früherkennung</h4>
      <p>Fälle mit Eskalationspotenzial werden frühzeitig identifiziert — bevor die Kosten steigen. Automatisches Flagging für Fallkonferenzen.</p>
    </div>
    <div class="solution-card">
      <h4>Träger-Benchmarking</h4>
      <p>Welcher Träger hat welche Verweildauern, Rückführungsquoten, Kostenprofile? Systematischer Vergleich als Grundlage informierter Hilfeplangespräche.</p>
    </div>
    <div class="solution-card">
      <h4>Steuerungscockpit für die Führung</h4>
      <p>Kämmerei und Dezernatsleitung erhalten ein Dashboard mit den entscheidungsrelevanten Kennzahlen — ohne in Fallakten einzutauchen.</p>
    </div>
  </div>
</div>

<!-- Zitat -->
<div class="quote-section">
  <div class="quote-inner">
    <div class="quote-text">„Was 2013 in Mannheim manuell gelang, kann heute datengestützt und systematisch umgesetzt werden — unabhängig davon, wer gerade Jugendamtsdirektor ist."</div>
    <div class="quote-source">Der Kämmerer · Analyse Mannheim 2013</div>
  </div>
</div>

<!-- ROI -->
<div class="section">
  <div class="section-label">Wirtschaftlichkeit</div>
  <h2>Was ASCEND konkret bringt</h2>
  <p class="section-sub">Pilotkommunen berichten von messbaren Effekten innerhalb der ersten 12 Monate — ohne Personalabbau, ohne Leistungskürzung.</p>

  <div class="roi-grid">
    <div class="roi-card">
      <div class="roi-val">−18 %</div>
      <div class="roi-label">Reduzierung stationärer Maßnahmen in Pilotkommunen</div>
    </div>
    <div class="roi-card">
      <div class="roi-val">10–14×</div>
      <div class="roi-label">ROI der Jahreslizenz durch Kosteneinsparung</div>
    </div>
    <div class="roi-card">
      <div class="roi-val">ab 48k</div>
      <div class="roi-label">Jahreslizenz — abhängig von der kommunalen Fallzahl</div>
    </div>
    <div class="roi-card">
      <div class="roi-val">0</div>
      <div class="roi-label">Systemwechsel oder IT-Integration erforderlich</div>
    </div>
  </div>
</div>

<!-- CTA -->
<div class="cta-section">
  <div class="cta-inner">
    <h2>Drei Fragen, die jede kommunale Führung beantworten können sollte</h2>
    <p>Wie hoch ist Ihr Anteil stationärer HzE-Maßnahmen im Vergleich zu strukturähnlichen Kommunen? Welche Träger haben die längsten Verweildauern? Welche Fälle werden nächsten Monat teurer? — ASCEND beantwortet diese Fragen.</p>
    <a href="#demoForm" class="cta-btn" onclick="document.getElementById('demoForm').scrollIntoView({behavior:'smooth'});return false;">
      Demo-Termin anfragen →
    </a>
  </div>
</div>

<Footer />

<script is:inline>
  document.getElementById('demoForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const btn = document.getElementById('demoSubmit');
    btn.textContent = 'Wird gesendet …';
    btn.disabled = true;

    const data = Object.fromEntries(new FormData(this));
    try {
      await fetch('/api/demo-anfrage', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(data)
      });
    } catch(e) {}

    this.style.display = 'none';
    document.getElementById('demoOk').style.display = 'block';
  });
</script>
</Base>
