---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<Base
  title="Stellenanzeigen schalten – KommunalFlat"
  description="Unlimitierte Stellenanzeigen auf derkaemmerer.de für 249 € / Monat. Inklusive individuellem Stadt-Dossier, Newsletter-Erwähnung und LinkedIn-Verbreitung."
>
<Header />

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" rel="stylesheet">

<style>
:root {
  --navy:   #172840;
  --ink:    #0f172a;
  --blue:   #2563eb;
  --blue2:  #1d4ed8;
  --light:  #f0f4f8;
  --border: #cbd5e1;
  --muted:  #64748b;
  --white:  #ffffff;
  --cream:  #f8fafc;
}
* { box-sizing: border-box; }
.wrap { max-width: 1060px; margin: 0 auto; padding: 0 32px; }

/* ── HERO ── */
.hero {
  background: var(--navy);
  color: white;
  padding: 88px 32px 80px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse at 15% 60%, rgba(37,99,235,0.25) 0%, transparent 55%),
    radial-gradient(ellipse at 85% 20%, rgba(37,99,235,0.18) 0%, transparent 50%);
  pointer-events: none;
}
.hero-inner { position: relative; z-index: 1; max-width: 720px; margin: 0 auto; }
.hero-kicker {
  display: inline-flex; align-items: center; gap: 10px;
  font-size: 10px; font-weight: 600; letter-spacing: 4px;
  text-transform: uppercase; color: #93c5fd; margin-bottom: 22px;
}
.hero-kicker::before, .hero-kicker::after {
  content: ''; width: 28px; height: 1px; background: #93c5fd; opacity: 0.5;
}
.hero h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(38px, 5.5vw, 62px);
  font-weight: 700; line-height: 1.08; letter-spacing: -1.5px;
  color: white; margin-bottom: 22px;
}
.hero h1 em { font-style: italic; color: #93c5fd; }
.hero-sub {
  font-size: 17px; color: rgba(255,255,255,0.6);
  max-width: 520px; margin: 0 auto 48px; line-height: 1.75;
}

/* Preis-Block */
.price-block {
  display: inline-block;
  border: 1px solid rgba(255,255,255,0.15);
  padding: 28px 48px; margin-bottom: 12px;
  background: rgba(255,255,255,0.05);
}
.price-row {
  display: flex; align-items: baseline;
  justify-content: center; gap: 4px; margin-bottom: 8px;
}
.price-eur {
  font-size: 22px; color: rgba(255,255,255,0.45);
  font-weight: 300; align-self: flex-start; margin-top: 10px;
}
.price-num {
  font-family: 'Playfair Display', serif;
  font-size: 64px; font-weight: 700; color: white; line-height: 1;
}
.price-period {
  font-size: 15px; color: rgba(255,255,255,0.4);
  align-self: flex-end; margin-bottom: 8px;
}
.price-incl { font-size: 12px; color: #93c5fd; letter-spacing: 1px; text-align: center; }
.price-note {
  font-size: 12px; color: rgba(255,255,255,0.35);
  margin-bottom: 36px; line-height: 1.7;
}
.btn-hero {
  display: inline-block; background: var(--blue);
  color: white; padding: 17px 44px; font-size: 15px;
  font-weight: 600; text-decoration: none; letter-spacing: 0.3px;
  transition: background 0.2s;
}
.btn-hero:hover { background: var(--blue2); }

/* ── DOSSIER ── */
.dossier {
  background: var(--ink); color: white;
  padding: 72px 32px; border-top: 4px solid var(--blue);
}
.dossier-grid {
  max-width: 1060px; margin: 0 auto;
  display: grid; grid-template-columns: 1fr 420px;
  gap: 64px; align-items: center;
}
.dossier-kicker {
  font-size: 10px; font-weight: 700; letter-spacing: 4px;
  text-transform: uppercase; color: #93c5fd; margin-bottom: 14px;
}
.dossier h2 {
  font-family: 'Playfair Display', serif;
  font-size: 34px; font-weight: 700; color: white;
  line-height: 1.15; margin-bottom: 16px;
}
.dossier h2 em { font-style: italic; color: #93c5fd; }
.dossier-text {
  font-size: 15px; color: rgba(255,255,255,0.6);
  line-height: 1.8; margin-bottom: 24px;
}
.dossier-items {
  list-style: none;
  display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
}
.dossier-items li {
  font-size: 13px; color: rgba(255,255,255,0.65);
  display: flex; align-items: flex-start; gap: 8px; line-height: 1.5;
}
.dossier-items li::before { content: '→'; color: #93c5fd; font-weight: 600; flex-shrink: 0; }

/* Dossier Card */
.dossier-card { background: var(--white); overflow: hidden; box-shadow: 0 24px 64px rgba(0,0,0,0.4); }
.dc-header {
  background: var(--navy); padding: 18px 22px;
  display: flex; align-items: center; gap: 12px;
}
.dc-icon {
  width: 40px; height: 40px; background: var(--blue);
  display: flex; align-items: center; justify-content: center;
  font-family: 'Playfair Display', serif; font-size: 15px;
  font-weight: 700; color: white; flex-shrink: 0;
}
.dc-header-text .dc-title { font-size: 14px; font-weight: 600; color: white; line-height: 1.2; }
.dc-header-text .dc-sub { font-size: 10px; color: rgba(255,255,255,0.45); letter-spacing: 1px; text-transform: uppercase; }
.dc-body { padding: 20px 22px; }
.dc-section { margin-bottom: 14px; padding-bottom: 14px; border-bottom: 1px solid var(--light); }
.dc-section:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
.dc-label { font-size: 9px; font-weight: 700; letter-spacing: 2.5px; text-transform: uppercase; color: var(--blue); margin-bottom: 5px; }
.dc-text { font-size: 12px; color: var(--muted); line-height: 1.6; }
.dc-pills { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 6px; }
.dc-pill { background: var(--light); border: 1px solid var(--border); font-size: 10px; padding: 2px 8px; color: var(--muted); }
.dc-quote { font-style: italic; font-size: 12px; color: var(--muted); line-height: 1.6; padding-left: 10px; border-left: 2px solid var(--blue); }

/* ── LEISTUNGEN ── */
.leistungen {
  padding: 72px 0;
  background: var(--cream);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}
.leistungen-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 2px; background: var(--border);
  border: 1px solid var(--border); margin-top: 40px;
}
.leistung { background: var(--white); padding: 28px 24px; }
.leistung-num {
  font-family: 'Playfair Display', serif; font-size: 11px;
  color: var(--blue); font-weight: 600; letter-spacing: 2px; margin-bottom: 10px;
}
.leistung h4 { font-size: 15px; font-weight: 600; color: var(--ink); margin-bottom: 8px; line-height: 1.3; }
.leistung p { font-size: 13px; color: var(--muted); line-height: 1.7; }

/* ── VERTRAG ── */
.vertrag { padding: 64px 0; }
.vertrag-box {
  background: var(--navy); color: white;
  padding: 40px 48px;
  display: grid; grid-template-columns: 1fr 1fr; gap: 48px;
}
.vertrag-box h3 {
  font-family: 'Playfair Display', serif;
  font-size: 22px; font-weight: 600; color: white;
  margin-bottom: 20px; grid-column: 1 / -1;
}
.vertrag-items { list-style: none; }
.vertrag-items li {
  font-size: 13px; color: rgba(255,255,255,0.7);
  padding: 9px 0; border-bottom: 1px solid rgba(255,255,255,0.08);
  display: flex; gap: 12px; line-height: 1.5;
}
.vertrag-items li:last-child { border-bottom: none; }
.vertrag-items li strong { color: white; min-width: 140px; flex-shrink: 0; font-weight: 500; }

/* ── PROZESS ── */
.prozess { padding: 72px 0; background: var(--cream); border-top: 1px solid var(--border); }
.prozess-steps {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 0; margin-top: 48px; position: relative;
}
.prozess-steps::before {
  content: ''; position: absolute;
  top: 20px; left: calc(12.5% + 8px); right: calc(12.5% + 8px);
  height: 1px; background: var(--border); z-index: 0;
}
.pstep { text-align: center; padding: 0 16px; position: relative; z-index: 1; }
.pstep-num {
  width: 40px; height: 40px; background: var(--navy); color: white;
  font-family: 'Playfair Display', serif; font-size: 17px; font-weight: 700;
  display: flex; align-items: center; justify-content: center; margin: 0 auto 16px;
}
.pstep h4 { font-size: 13px; font-weight: 600; color: var(--ink); margin-bottom: 6px; line-height: 1.3; }
.pstep p { font-size: 12px; color: var(--muted); line-height: 1.6; }

/* ── REICHWEITE ── */
.reichweite { background: var(--navy); padding: 56px 32px; color: white; }
.reichweite-grid {
  max-width: 1060px; margin: 0 auto;
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 2px; background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.1);
}
.rw-card { background: rgba(255,255,255,0.04); padding: 28px 20px; text-align: center; }
.rw-num {
  font-family: 'Playfair Display', serif; font-size: 40px;
  font-weight: 700; color: white; line-height: 1; margin-bottom: 6px;
}
.rw-label { font-size: 11px; text-transform: uppercase; letter-spacing: 1.5px; color: rgba(255,255,255,0.4); line-height: 1.4; }

/* ── FAQ ── */
.faq { padding: 72px 0; background: var(--cream); border-top: 1px solid var(--border); }
.faq-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 40px; }
.faq-item {
  background: var(--white); border: 1px solid var(--border);
  padding: 24px; border-left: 3px solid var(--navy);
}
.faq-item h4 { font-size: 14px; font-weight: 600; color: var(--ink); margin-bottom: 8px; line-height: 1.4; }
.faq-item p { font-size: 13px; color: var(--muted); line-height: 1.7; }

/* ── CTA FINAL ── */
.cta-final { background: var(--ink); padding: 88px 32px; text-align: center; color: white; }
.cta-final h2 {
  font-family: 'Playfair Display', serif;
  font-size: 40px; font-weight: 700; color: white;
  margin-bottom: 16px; line-height: 1.15;
}
.cta-final h2 em { font-style: italic; color: #93c5fd; }
.cta-final p {
  font-size: 16px; color: rgba(255,255,255,0.55);
  margin-bottom: 40px; max-width: 480px;
  margin-left: auto; margin-right: auto; line-height: 1.75;
}
.btn-final {
  display: inline-block; background: var(--blue);
  color: white; padding: 18px 48px; font-size: 15px;
  font-weight: 600; text-decoration: none;
  transition: background 0.2s; letter-spacing: 0.3px;
}
.btn-final:hover { background: var(--blue2); }
.cta-note { margin-top: 20px; font-size: 12px; color: rgba(255,255,255,0.3); line-height: 1.7; }

/* ── SECTION LABELS ── */
.sec-kicker { font-size: 10px; font-weight: 700; letter-spacing: 4px; text-transform: uppercase; color: var(--blue); margin-bottom: 10px; }
.sec-title { font-family: 'Playfair Display', serif; font-size: 32px; font-weight: 700; color: var(--ink); line-height: 1.15; margin-bottom: 12px; }
.sec-sub { font-size: 15px; color: var(--muted); line-height: 1.75; max-width: 540px; }

@media (max-width: 900px) {
  .dossier-grid { grid-template-columns: 1fr; }
  .dossier-card { display: none; }
}
@media (max-width: 768px) {
  .leistungen-grid { grid-template-columns: 1fr 1fr; }
  .vertrag-box { grid-template-columns: 1fr; padding: 28px 24px; }
  .prozess-steps { grid-template-columns: 1fr 1fr; }
  .prozess-steps::before { display: none; }
  .reichweite-grid { grid-template-columns: repeat(2,1fr); }
  .faq-grid { grid-template-columns: 1fr; }
}
@media (max-width: 480px) {
  .leistungen-grid { grid-template-columns: 1fr; }
  .price-block { padding: 20px 28px; }
  .price-num { font-size: 52px; }
}
</style>

<!-- HERO -->
<div class="hero" id="buchen">
  <div class="hero-inner">
    <div class="hero-kicker">Stellenbörse</div>
    <h1>Ein Angebot.<br><em>Unlimitiert.</em><br>Ihr Stadt-Dossier inklusive.</h1>
    <p class="hero-sub">
      Keine Pakete, keine Verwirrung, keine Einzelabrechnung.
      Nur eine monatliche Pauschale – und wir kümmern uns um alles.
    </p>

    <div class="price-block">
      <div class="price-row">
        <span class="price-eur">€</span>
        <span class="price-num">249</span>
        <span class="price-period">/Monat</span>
      </div>
      <div class="price-incl">✓ Unlimitierte Stellenanzeigen &nbsp;·&nbsp; ✓ Stadt-Dossier inklusive</div>
    </div>

    <div class="price-note">
      12-Monatsvertrag · Erstmalig kündbar zum Ablauf des 12. Monats<br>
      Danach monatlich kündbar zum Monatsende · Keine Mindestanzeigenanzahl
    </div>

    <a href="mailto:anzeigen@derkaemmerer.de?subject=KommunalFlat%20buchen" class="btn-hero">
      Jetzt KommunalFlat buchen →
    </a>
  </div>
</div>

<!-- DOSSIER -->
<div class="dossier">
  <div class="dossier-grid">
    <div>
      <div class="dossier-kicker">Exklusiv für jeden Kunden</div>
      <h2>„<em>Deine Stadt X</em><br>als Arbeitgeber"</h2>
      <p class="dossier-text">
        Jeder kommunale Arbeitgeber auf derkaemmerer.de erhält ein professionell
        erstelltes Stadt-Dossier – individuell, kostenlos und dauerhaft auf unserer
        Plattform veröffentlicht. Wir arbeiten gemeinsam mit Ihnen die Vorzüge,
        Besonderheiten und Alleinstellungsmerkmale Ihrer Kommune heraus.
      </p>
      <p class="dossier-text">
        Das Dossier erscheint neben jeder Ihrer Stellenanzeigen und macht aus
        einer gewöhnlichen Ausschreibung ein echtes Arbeitgeberversprechen.
      </p>
      <ul class="dossier-items">
        <li>Lage, Lebensqualität &amp; Region</li>
        <li>TVöD-Eingruppierung &amp; Benefits</li>
        <li>Karriere &amp; Entwicklungswege</li>
        <li>Homeoffice &amp; Work-Life-Balance</li>
        <li>Besonderheiten Ihrer Kommune</li>
        <li>Stimmen aus Ihrem Team</li>
        <li>Freizeitmöglichkeiten &amp; Familie</li>
        <li>Infrastruktur &amp; Erreichbarkeit</li>
      </ul>
    </div>

    <div class="dossier-card">
      <div class="dc-header">
        <div class="dc-icon">LK</div>
        <div class="dc-header-text">
          <div class="dc-title">Landkreis Musterstadt</div>
          <div class="dc-sub">Deine Stadt als Arbeitgeber · derkaemmerer.de</div>
        </div>
      </div>
      <div class="dc-body">
        <div class="dc-section">
          <div class="dc-label">Warum Musterstadt?</div>
          <div class="dc-text">Naturnahe Lage, exzellente Infrastruktur, familienfreundliches Umfeld. Niedrige Lebenshaltungskosten bei hoher Lebensqualität.</div>
        </div>
        <div class="dc-section">
          <div class="dc-label">Was wir bieten</div>
          <div class="dc-text">TVöD EG 9–14 · 30 Tage Urlaub · Homeoffice bis 60% · Jobticket · Betriebliche Altersvorsorge</div>
          <div class="dc-pills">
            <span class="dc-pill">TVöD</span>
            <span class="dc-pill">Homeoffice</span>
            <span class="dc-pill">Jobticket</span>
            <span class="dc-pill">Kita-Plätze</span>
          </div>
        </div>
        <div class="dc-section">
          <div class="dc-label">Karriere &amp; Entwicklung</div>
          <div class="dc-text">Interne Fortbildungsakademie · Führungskräfteprogramm · Studienförderung möglich</div>
        </div>
        <div class="dc-section">
          <div class="dc-label">Stimme aus dem Team</div>
          <div class="dc-quote">
            „Hier gestalte ich echte kommunale Zukunft – nicht nur Akten."
            <br><strong style="font-style:normal;font-size:10px;color:#94a3b8;font-weight:500;">– Kämmerin, seit 2021</strong>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- LEISTUNGEN -->
<div class="leistungen">
  <div class="wrap">
    <div class="sec-kicker">Was Sie bekommen</div>
    <h2 class="sec-title">Alles inklusive. Immer.</h2>
    <p class="sec-sub">Ein Preis. Keine Zusatzkosten. Keine Überraschungen.</p>
    <div class="leistungen-grid">
      <div class="leistung">
        <div class="leistung-num">01</div>
        <h4>Unlimitierte Stellenanzeigen</h4>
        <p>Schalten Sie so viele Stellen wie Sie möchten – Kämmerei, Jugendamt, Hauptamt, IT. Keine Begrenzung, keine Aufpreise.</p>
      </div>
      <div class="leistung">
        <div class="leistung-num">02</div>
        <h4>Professionelle Gestaltung</h4>
        <p>Wir gestalten jede Anzeige im derkaemmerer.de-Design mit Ihrem Logo. Sie liefern Text – wir machen den Rest in 24 Stunden.</p>
      </div>
      <div class="leistung">
        <div class="leistung-num">03</div>
        <h4>Ihr Stadt-Dossier</h4>
        <p>Ein professionelles, individuelles Arbeitgeberprofil „Deine Stadt X als Arbeitgeber" – dauerhaft veröffentlicht und mit jeder Anzeige verknüpft.</p>
      </div>
      <div class="leistung">
        <div class="leistung-num">04</div>
        <h4>Newsletter-Erwähnung</h4>
        <p>Jede neue Stelle wird einmal im wöchentlichen Newsletter von derkaemmerer.de erwähnt – direkt in den Postfächern kommunaler Entscheider.</p>
      </div>
      <div class="leistung">
        <div class="leistung-num">05</div>
        <h4>LinkedIn-Verbreitung</h4>
        <p>Neue Stellen werden auf dem derkaemmerer.de LinkedIn-Profil geteilt – gezielt an kommunale Fachkräfte und Verwaltungsexperten.</p>
      </div>
      <div class="leistung">
        <div class="leistung-num">06</div>
        <h4>Direkte Bewerberweitergabe</h4>
        <p>Bewerbungen landen direkt in Ihrem System oder per E-Mail. Kein Zwischenportal, kein Datenverlust, keine Verzögerung.</p>
      </div>
    </div>
  </div>
</div>

<!-- VERTRAG -->
<div class="vertrag">
  <div class="wrap">
    <div class="sec-kicker">Transparent &amp; fair</div>
    <h2 class="sec-title">Die Vertragsbedingungen</h2>
    <p class="sec-sub" style="margin-bottom:32px;">Klar, einfach und kommunal-kompatibel – kein Kleingedrucktes.</p>
    <div class="vertrag-box">
      <h3>KommunalFlat – Alle Konditionen auf einen Blick</h3>
      <ul class="vertrag-items">
        <li><strong>Monatspreis</strong> 249,00 € zzgl. 19 % MwSt.</li>
        <li><strong>Vertragslaufzeit</strong> 12 Monate ab Vertragsbeginn</li>
        <li><strong>Erstmalige Kündigung</strong> zum Ablauf des 12. Monats</li>
        <li><strong>Kündigungsfrist</strong> 1 Monat zum Monatsende</li>
        <li><strong>Nach dem 12. Monat</strong> monatlich kündbar</li>
      </ul>
      <ul class="vertrag-items">
        <li><strong>Stellenanzeigen</strong> Unlimitiert, alle Kategorien</li>
        <li><strong>Stadt-Dossier</strong> 1× pro Kommune, dauerhaft</li>
        <li><strong>Vergabepflicht</strong> Direktauftrag unter Schwellenwert</li>
        <li><strong>Rechnungsstellung</strong> Monatlich, 14 Tage Zahlungsziel</li>
        <li><strong>Kündigung</strong> Per E-Mail, keine Form erforderlich</li>
      </ul>
    </div>
  </div>
</div>

<!-- PROZESS -->
<div class="prozess">
  <div class="wrap">
    <div class="sec-kicker">In 4 Schritten</div>
    <h2 class="sec-title">Von der Anfrage zur geschalteten Stelle</h2>
    <div class="prozess-steps">
      <div class="pstep">
        <div class="pstep-num">1</div>
        <h4>Anfrage per E-Mail</h4>
        <p>Schreiben Sie uns – wir antworten innerhalb von 1 Werktag und senden Ihnen den Vertrag.</p>
      </div>
      <div class="pstep">
        <div class="pstep-num">2</div>
        <h4>Dossier-Fragebogen</h4>
        <p>Wir senden einen kurzen Fragebogen. In 48 Stunden steht Ihr individuelles Stadt-Dossier.</p>
      </div>
      <div class="pstep">
        <div class="pstep-num">3</div>
        <h4>Erste Stelle einreichen</h4>
        <p>Text und Logo per E-Mail – wir schalten innerhalb von 24 Stunden. Immer.</p>
      </div>
      <div class="pstep">
        <div class="pstep-num">4</div>
        <h4>Bewerbungen empfangen</h4>
        <p>Qualifizierte Fachkräfte aus der kommunalen Welt bewerben sich direkt bei Ihnen.</p>
      </div>
    </div>
  </div>
</div>

<!-- REICHWEITE -->
<div class="reichweite">
  <div class="reichweite-grid">
    <div class="rw-card">
      <div class="rw-num">294</div>
      <div class="rw-label">Landkreise<br>Deutschland</div>
    </div>
    <div class="rw-card">
      <div class="rw-num">11.000+</div>
      <div class="rw-label">Kommunen<br>im Einzugsgebiet</div>
    </div>
    <div class="rw-card">
      <div class="rw-num">8.500+</div>
      <div class="rw-label">Kämmerer &amp;<br>Fachkräfte</div>
    </div>
    <div class="rw-card">
      <div class="rw-num">Ø 12</div>
      <div class="rw-label">Tage bis zur<br>ersten Bewerbung</div>
