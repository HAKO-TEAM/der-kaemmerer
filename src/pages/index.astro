---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const haushalt  = await getCollection('haushalt');
const einnahmen = await getCollection('einnahmen');
const ausgaben  = await getCollection('ausgaben');
const praxis    = await getCollection('praxis');
const recht     = await getCollection('recht');
const analyse      = await getCollection('analyse');
const sozialkosten = await getCollection('sozialkosten');

const alle = [...haushalt,...einnahmen,...ausgaben,...praxis,...recht,...analyse,...sozialkosten]
  .sort((a,b) => new Date(b.data.datum).getTime() - new Date(a.data.datum).getTime());

const featured  = alle.find(a => a.data.featured) || alle[0];
const neueste   = alle.filter(a => a.id !== featured?.id).slice(0, 8);

const catColor: Record<string,string> = {
  haushalt:'#c2410c', einnahmen:'#3b82f6', ausgaben:'#1e40af',
  praxis:'#92400e', recht:'#6b21a8', analyse:'#374151', sozialkosten:'#be123c'
};
const catLabel: Record<string,string> = {
  haushalt:'Haushalt', einnahmen:'Einnahmen', ausgaben:'Ausgaben steuern',
  praxis:'Best Practice', recht:'Recht & Vergabe', analyse:'Analyse', sozialkosten:'Sozialkosten'
};
---
<Base title="Der Kämmerer – Das Briefing für kommunale Entscheider">
<Header />
<style>
  .hero-grid{display:grid;grid-template-columns:1fr 320px;gap:44px;max-width:1200px;margin:0 auto;padding:0 32px}
  .kpi-band-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:0}
  .kpi-band-item{padding:0 20px 0 0;margin:0 20px 0 0}
  .kpi-band-item:last-child{border-right:none}
  .art-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:40px}
  .nl-inner{display:flex;justify-content:space-between;align-items:center;gap:24px;max-width:1200px;margin:0 auto;padding:0 32px}
  .nl-form{display:flex;gap:8px}
  .main-inner{max-width:1200px;margin:0 auto;padding:36px 32px}
  @media(max-width:1024px){
    .hero-grid{grid-template-columns:1fr;gap:24px;padding:0 20px}
    .hero-sidebar{border-left:none;border-top:1px solid #1e3a5f;padding-left:0;padding-top:20px}
    .kpi-band-grid{grid-template-columns:repeat(2,1fr);gap:16px}
    .kpi-band-item{padding:0;margin:0;border-right:none!important}
    .art-grid{grid-template-columns:repeat(2,1fr)}
  }
  @media(max-width:768px){
    .hero-grid{padding:0 16px}
    .hero-sidebar{display:none}
    .kpi-band-grid{grid-template-columns:repeat(2,1fr);gap:12px}
    .art-grid{grid-template-columns:1fr}
    .nl-inner{flex-direction:column;align-items:flex-start;padding:0 16px}
    .nl-form{width:100%}
    .nl-form input{flex:1;min-width:0}
    .main-inner{padding:24px 16px}
    .hero-h1-mobile{font-size:22px!important;line-height:1.2!important}
  }
</style>
<!-- Hero -->
<section style="background:linear-gradient(135deg,#1a2744 0%,#0f3460 60%,#1a3a5c 100%);padding:48px 0;">
  <div class="hero-grid">
    {featured && (
    <div>
      <div style="font-size:9px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#6ee7b7;margin-bottom:12px;">
        Leitartikel · {featured.data.datum}
      </div>
      <h1 style="font-size:30px;font-weight:800;line-height:1.15;color:#fff;margin-bottom:12px;letter-spacing:-.02em;" class="hero-h1-mobile">
        {featured.data.title}
      </h1>
      <p style="font-size:14px;color:#93c5fd;line-height:1.7;margin-bottom:14px;">{featured.data.beschreibung}</p>
      <a href={`/${featured.collection}/${(featured.id as string).split("/").pop()!.replace(".md","")}`}
         style="display:inline-block;background:#3b82f6;color:#fff;font-size:10px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;padding:9px 16px;border-radius:3px;">
        Weiterlesen →
      </a>
    </div>
    )}
    <div class="hero-sidebar" style="border-left:1px solid #1e3a5f;padding-left:28px;">
      <div style="font-size:9px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#6b7280;margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid #1e3a5f;">
        Neueste Artikel
      </div>
      {neueste.slice(0,4).map(a => (
      <div style="padding:10px 0;border-bottom:1px solid #1a2f50;">
        <div style={`font-size:9px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#6ee7b7;margin-bottom:3px;`}>
          {catLabel[a.collection]}
        </div>
        <a href={`/${a.collection}/${(a.id as string).split("/").pop()!.replace(".md","")}`}
           style="font-size:12px;font-weight:500;color:#e2e8f0;line-height:1.4;display:block;">
          {a.data.title}
        </a>
      </div>
      ))}
    </div>
  </div>
</section>

<!-- KPI-Band -->
<div style="background:#1a2744;padding:26px 0;">
  <div class="main-inner" style="padding-top:0;padding-bottom:0;">
    <div style="font-size:9px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#3b82f6;margin-bottom:14px;">
      Kommunale Haushaltslage Deutschland 2026 · Quellen: Statistisches Bundesamt · KfW · Bertelsmann Stiftung
    </div>
    <div class="kpi-band-grid">
      {[
        {val:'166 Mrd.',desc:'Kommunaler Investitionsstau',src:'KfW-Kommunalpanel 2025'},
        {val:'70 %',desc:'Kommunen strukturell im Defizit',src:'KGSt / BMF 2026'},
        {val:'+44 %',desc:'HzE-Kostensteigerung seit 2013',src:'Ø deutsche Großstädte'},
        {val:'28,4 Mrd.',desc:'Asyl- und Integrationskosten 2025',src:'Bund / Länder / Kommunen'},
      ].map((k,i) => (
      <div class="kpi-band-item" style={i<3?'border-right:1px solid #1e3a5f;':''}>
        <div style="font-size:26px;font-weight:800;color:#fff;line-height:1;margin-bottom:4px;">{k.val}</div>
        <div style="font-size:11px;color:#93c5fd;font-weight:500;line-height:1.4;">{k.desc}</div>
        <div style="font-size:9px;color:#374151;margin-top:2px;">{k.src}</div>
      </div>
      ))}
    </div>
  </div>
</div>

<!-- Hauptinhalt -->
<main class="main-inner">

  <!-- Alle neuesten Artikel -->
  {alle.length > 0 && (
  <div>
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:22px;padding-bottom:6px;border-bottom:3px solid #1a2744;">
      <span style="font-size:16px;font-weight:800;color:#1a2744;">Aktuelle Beiträge</span>
      <span style="flex:1;height:1px;background:#e2e8f0;"></span>
      <span style="font-size:9px;font-weight:600;color:#6b7280;letter-spacing:.08em;text-transform:uppercase;">{alle.length} Artikel</span>
    </div>
    <div class="art-grid">
      {alle.slice(0,6).map(a => (
      <div>
        <span style={`font-size:9px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:${catColor[a.collection]};display:block;margin-bottom:6px;`}>
          {catLabel[a.collection]}
        </span>
        {a.data.tag === 'neu' && <span style="display:inline-block;background:#fef2f2;color:#c2410c;border:1px solid #fed7aa;font-size:9px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;padding:1px 6px;border-radius:2px;margin-bottom:6px;">Neu</span>}
        <a href={`/${a.collection}/${(a.id as string).split("/").pop()!.replace(".md","")}`}>
          <h3 style="font-size:15px;font-weight:700;line-height:1.3;color:#1a2744;margin-bottom:6px;letter-spacing:-.01em;">{a.data.title}</h3>
        </a>
        <p style="font-size:12px;color:#374151;line-height:1.6;margin-bottom:6px;">{a.data.beschreibung}</p>
        <span style="font-size:10px;color:#6b7280;">{a.data.autor} · {a.data.minuten} Min.</span>
      </div>
      ))}
    </div>
  </div>
  )}

  <!-- Newsletter -->
  <div id="newsletter" style="background:#fff;border:1px solid #e2e8f0;padding:32px;margin-bottom:0;">
    <div class="nl-inner">
      <h3 style="font-size:18px;font-weight:800;color:#1a2744;margin-bottom:4px;">Das wöchentliche Briefing</h3>
      <p style="font-size:12px;color:#374151;">Jeden Montag: die wichtigsten Entwicklungen für kommunale Entscheider. Kostenlos.</p>
    </div>
    <form style="display:flex;gap:8px;" onsubmit="return false;">
      <input type="email" placeholder="Dienstliche E-Mail-Adresse"
        style="padding:9px 14px;font-size:12px;border:1px solid #e2e8f0;border-radius:3px;width:240px;outline:none;">
      <button style="padding:9px 16px;font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;background:#3b82f6;color:#fff;border:none;border-radius:3px;cursor:pointer;">
        Abonnieren
      </button>
    </form>
  </div>

</main>
<Footer />
</Base>
