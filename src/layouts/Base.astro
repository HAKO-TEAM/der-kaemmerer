---
export interface Props {
  title: string;
  description?: string;
  canonical?: string;
}
const {
  title,
  description = 'Das unabhängige Briefing für Kämmerer, Oberbürgermeister und Finanzdezernenten. Analysen, Maßnahmen und Best Practice für kommunale Haushalte.',
  canonical,
} = Astro.props;
const url = canonical || `https://derkaemmerer.de${Astro.url.pathname}`;
---
<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title} — Der Kämmerer</title>
<meta name="description" content={description}>
<link rel="canonical" href={url}>
<meta name="robots" content="index, follow">
<!-- Open Graph -->
<meta property="og:type" content="website">
<meta property="og:site_name" content="Der Kämmerer">
<meta property="og:title" content={`${title} — Der Kämmerer`}>
<meta property="og:description" content={description}>
<meta property="og:url" content={url}>
<meta property="og:locale" content="de_DE">
<!-- Twitter/X -->
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content={`${title} — Der Kämmerer`}>
<meta name="twitter:description" content={description}>
<!-- Sitemap -->
<link rel="sitemap" href="/sitemap.xml">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --navy:#1a2744; --navy2:#0f3460; --navy3:#1a3a5c;
    --blue:#3b82f6; --blue-lt:#93c5fd; --blue-bg:#eff6ff;
    --amber:#c2410c; --amber-lt:#fed7aa;
    --green:#065f46; --green-lt:#6ee7b7;
    --purple:#6b21a8; --gold:#92400e;
    --ink:#1a1a2e; --mid:#374151; --lt:#6b7280;
    --rule:#e2e8f0; --bg:#f8fafc; --white:#fff;
    --font:'Inter','Helvetica Neue',Helvetica,Arial,sans-serif;
  }
  *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
  html{font-size:15px;scroll-behavior:smooth}
  body{font-family:var(--font);color:var(--ink);background:var(--bg);line-height:1.55;-webkit-font-smoothing:antialiased}
  a{text-decoration:none;color:inherit}
  img{max-width:100%;height:auto}
  /* ── Globale Responsive Utilities ── */
  @media(max-width:768px){
    .hide-mobile{display:none!important}
    .px-page{padding-left:16px!important;padding-right:16px!important}
  }
  @media(min-width:769px) and (max-width:1024px){
    .hide-tablet{display:none!important}
  }
</style>
</head>
<body>
  <slot />
</body>
</html>
