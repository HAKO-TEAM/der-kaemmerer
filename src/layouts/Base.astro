---
export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  datum?: string;
  autor?: string;
}
const {
  title,
  description = 'Das unabhängige Briefing für Kämmerer, Oberbürgermeister und Finanzdezernenten. Analysen, Maßnahmen und Best Practice für kommunale Haushalte.',
  canonical,
  ogType = 'website',
  ogImage = 'https://derkaemmerer.de/og-default.svg',
  datum,
  autor = 'Redaktion Der Kämmerer',
} = Astro.props;
const url = canonical || `https://derkaemmerer.de${Astro.url.pathname}`;
const fullTitle = `${title} — Der Kämmerer`;
---
<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{fullTitle}</title>
<meta name="description" content={description}>
<link rel="canonical" href={url}>
<meta name="robots" content="index, follow">
<meta name="author" content={autor}>

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="alternate icon" href="/favicon.ico">

<!-- Open Graph -->
<meta property="og:type" content={ogType}>
<meta property="og:site_name" content="Der Kämmerer">
<meta property="og:title" content={fullTitle}>
<meta property="og:description" content={description}>
<meta property="og:url" content={url}>
<meta property="og:locale" content="de_DE">
<meta property="og:image" content={ogImage}>
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
{ogType === 'article' && datum && <meta property="article:published_time" content={datum}>}
{ogType === 'article' && <meta property="article:author" content={autor}>}
{ogType === 'article' && <meta property="article:publisher" content="https://derkaemmerer.de">}

<!-- Twitter/X -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content={fullTitle}>
<meta name="twitter:description" content={description}>
<meta name="twitter:image" content={ogImage}>

<!-- JSON-LD -->
{ogType === 'article' ? (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "url": url,
    "datePublished": datum,
    "author": { "@type": "Organization", "name": "HAKO Beteiligungsgesellschaft mbH", "url": "https://derkaemmerer.de" },
    "publisher": {
      "@type": "Organization",
      "name": "Der Kämmerer",
      "url": "https://derkaemmerer.de",
      "logo": { "@type": "ImageObject", "url": "https://derkaemmerer.de/favicon.svg" }
    },
    "image": ogImage,
    "inLanguage": "de-DE"
  })} />
) : (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Der Kämmerer",
    "url": "https://derkaemmerer.de",
    "description": description,
    "publisher": {
      "@type": "Organization",
      "name": "HAKO Beteiligungsgesellschaft mbH",
      "url": "https://www.hako.team"
    }
  })} />
)}

<!-- Sitemap -->
<link rel="sitemap" href="/sitemap.xml">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --navy:#1a2744; --navy2:#0f3460; --navy3:#1a3a5c;
    --blue:#3b82f6; --blue-lt:#93c5fd; --blue-bg:#eff6ff;
    --amber:#c2410c; --amber-lt:#fed7aa;
    --green:#065f46; --green-lt:#6ee7b7;
    --purple:#6b21a8; --gold:#92400e;
    --ink:#1a1a2e; --mid:#374151; --lt:#6b7280;
    --rule:#e2e8f0; --bg:#f8fafc; --white:#fff;
    --font:'Inter','Helvetica Neue',Helvetica,Arial,sans-serif;
  }
  *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
  html{font-size:15px;scroll-behavior:smooth}
  body{font-family:var(--font);color:var(--ink);background:var(--bg);line-height:1.55;-webkit-font-smoothing:antialiased}
  a{text-decoration:none;color:inherit}
  img{max-width:100%;height:auto}
  /* ── Globale Responsive Utilities ── */
  @media(max-width:768px){
    .hide-mobile{display:none!important}
    .px-page{padding-left:16px!important;padding-right:16px!important}
  }
  @media(min-width:769px) and (max-width:1024px){
    .hide-tablet{display:none!important}
  }
</style>
</head>
<body>
  <slot />
  <script defer src="https://cdn.vercel-insights.com/v1/script.js" data-endpoint="/_vercel/insights"></script>
</body>
</html>
