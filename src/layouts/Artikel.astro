---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  beschreibung: string;
  ressort: string;
  datum: string;
  minuten: number;
  autor: string;
  tag?: string;
}
const { title, beschreibung, ressort, datum, minuten, autor, tag } = Astro.props;

const ressortLabels: Record<string,string> = {
  haushalt:'Haushalt & Finanzen', einnahmen:'Einnahmen erschließen',
  ausgaben:'Ausgaben steuern', praxis:'Best Practice',
  recht:'Recht & Vergabe', analyse:'Analyse & Meinung'
};
const ressortColors: Record<string,string> = {
  haushalt:'#c2410c', einnahmen:'#3b82f6', ausgaben:'#1e40af',
  praxis:'#92400e', recht:'#6b21a8', analyse:'#374151'
};
---
<Base title={title} description={beschreibung}>
  <Header />
  <div style="background:var(--navy);padding:36px 0;">
    <div style="max-width:780px;margin:0 auto;padding:0 32px;">
      <div style="font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#6ee7b7;margin-bottom:10px;">
        <a href={`/${ressort}`} style="color:#6ee7b7;">← {ressortLabels[ressort]}</a>
      </div>
      {tag && <span style={`display:inline-block;background:var(--blue);color:#fff;font-size:9px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:2px 8px;border-radius:2px;margin-bottom:10px;`}>{tag}</span>}
      <h1 style="font-size:28px;font-weight:800;color:#fff;line-height:1.2;letter-spacing:-.02em;margin-bottom:12px;">{title}</h1>
      <p style="font-size:14px;color:var(--blue-lt);line-height:1.6;margin-bottom:14px;">{beschreibung}</p>
      <div style="font-size:10px;color:#475569;letter-spacing:.04em;">
        {autor} &nbsp;·&nbsp; {datum} &nbsp;·&nbsp; {minuten} Minuten Lesezeit
      </div>
    </div>
  </div>

  <main style="max-width:780px;margin:40px auto;padding:0 32px 60px;">
    <article style="font-size:15px;line-height:1.75;color:var(--mid);">
      <style>
        article h2{font-size:20px;font-weight:800;color:var(--navy);margin:32px 0 12px;letter-spacing:-.01em}
        article h3{font-size:16px;font-weight:700;color:var(--navy);margin:24px 0 8px}
        article p{margin-bottom:16px}
        article ul,article ol{margin:0 0 16px 20px}
        article li{margin-bottom:6px}
        article strong{color:var(--navy);font-weight:700}
        article blockquote{border-left:3px solid var(--blue);padding:12px 16px;margin:20px 0;background:var(--blue-bg);border-radius:0 4px 4px 0;font-style:italic;color:var(--mid)}
        article blockquote p{margin:0}
        article .infobox{background:var(--blue-bg);border:1.5px solid var(--blue-lt);border-radius:6px;padding:16px 18px;margin:20px 0}
        article .warnbox{background:#fff7ed;border:1.5px solid var(--amber-lt);border-radius:6px;padding:16px 18px;margin:20px 0}
        article .greenbox{background:#f0fdf4;border:1.5px solid var(--green-lt);border-radius:6px;padding:16px 18px;margin:20px 0}
        article .box-title{font-size:10px;font-weight:700;color:var(--navy);letter-spacing:.06em;text-transform:uppercase;margin-bottom:6px}
        article hr{border:none;border-top:1px solid var(--rule);margin:32px 0}
        article table{width:100%;border-collapse:collapse;margin:20px 0;font-size:13px}
        article th{background:var(--navy);color:#fff;padding:8px 12px;text-align:left;font-weight:600;font-size:11px;letter-spacing:.04em}
        article td{padding:8px 12px;border-bottom:1px solid var(--rule)}
        article tr:nth-child(even) td{background:var(--bg)}
      </style>
      <slot />
    </article>
    <div style="border-top:1px solid var(--rule);margin-top:40px;padding-top:20px;font-size:11px;color:var(--lt);">
      © 2026 Der Kämmerer · HAKO Beteiligungsgesellschaft mbH · <a href="/" style="color:var(--blue);">Zur Startseite</a>
    </div>
  </main>
  <Footer />
</Base>
<style>
  @media(max-width:768px){
    .hero-art{padding:24px 16px!important}
    .hero-art h1{font-size:22px!important}
    main{padding:24px 16px 40px!important}
    article h2{font-size:18px!important}
  }
</style>
